{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
  ],
  minimumReleaseAge: "7 days",
  customManagers: [
    {
      customType: "regex",
      managerFilePatterns: [ "/^[^/]+/\\.config/nvim/lazy-lock\\.json$/" ],
      matchStrings: [ '"(?<depName>[^"]+)": { "branch": "(?<currentValue>[^"]+)", "commit": "(?<currentDigest>[^"]+)" }' ],
      datasourceTemplate: "github-digest",
    },
  ],
}
