{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
  ],
  minimumReleaseAge: "7 days",
  customManagers: [
    {
      customType: "regex",
      managerFilePatterns: [ "/^[^/]+/\\.config/nvim/lua/plugins\\.lua$/" ],
      matchStrings: [ '{\\s*"(?<depName>[^"]+)",\\s*branch = "(?<currentValue>[^"]+)",\\s*commit = "(?<currentDigest>[^"]+)"(,|\\s*})' ],
      datasourceTemplate: "github-digest",
    },
  ],
}
